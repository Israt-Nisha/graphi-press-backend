model Designer {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  name          String
  email         String  @unique
  profilePhoto  String?
  contactNumber String?
  address       String?
  displayName   String?
  bio           String? @db.Text
  expertise     String? @db.VarChar(255)
  portfolioUrl  String? @db.VarChar(512)

  rating              Float @default(0)
  totalReviews        Int   @default(0)
  totalAssignedItems  Int   @default(0)
  totalCompletedItems Int   @default(0)

  orders Order[] 
  orderItems OrderItem[] 
  orderItemAssignments OrderItemAssignment[]
  reviews Review[]

  isActive   Boolean   @default(true)
  isVerified Boolean   @default(false)
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId], name: "idx_designer_userId")
  @@index([email], name: "idx_designer_email")
  @@index([isActive], name: "idx_designer_isActive")
  @@index([isDeleted], name: "idx_designer_isDeleted")
  @@map("designers")
}
